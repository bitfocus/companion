{
  "name": "@companion-app/workspace",
  "version": "5.0.0",
  "packageManager": "yarn@4.17.1",
  "workspaces": [
    "companion",
    "config-tool",
    "shared-lib",
    "webui",
    "launcher",
    "launcher-ui",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "husky && run build:writefile && run build:whatsnew",
    "dev": "yarn workspace companion dev",
    "dev:inner": "yarn workspace companion dev:inner",
    "dev:debug": "yarn workspace companion dev:debug",
    "dev:webui": "yarn workspace @companion-app/webui dev",
    "dev:webui:docs": "tsx ./tools/webui-dev-docs.mts",
    "dev:docs": "yarn workspace @companion-app/docs start",
    "dev:storybook": "yarn workspace @companion-app/webui storybook",
    "build:ts": "tsc --build --force",
    "build:whatsnew": "tsx ./tools/build_whatsnew.mts",
    "build:config-reference": "tsx ./tools/generate_config_reference.mts",
    "dist:webui": "run build:ts && run build:whatsnew && run build:config-reference && yarn workspace @companion-app/webui build",
    "dist": "tsx ./tools/build/complete.mts",
    "macdist": "run dist mac-x64",
    "macarmdist": "run dist mac-arm64",
    "windist": "run dist win-x64",
    "lindist": "run dist linux-x64",
    "rpidist": "run dist linux-arm7",
    "format": "prettier --write .",
    "test": "vitest",
    "build:writefile": "tsx ./tools/build_writefile.mts",
    "build:openapi": "zx ./tools/generate_openapi.mjs",
    "build:graphics-types": "tsx ./tools/generate_graphics_types.mts",
    "build:satellite-schema": "tsx ./tools/satellite_schema_compile.mts",
    "draft:changelog": "tsx ./tools/draft_changelog.mts",
    "module:bulk": "zx ./tools/module_bulk.mjs",
    "build:watch": "tsc --build --watch",
    "check-types": "tsc --build",
    "watch-types": "run build:watch",
    "lint": "eslint"
  },
  "engines": {
    "npm": "please-use-yarn",
    "yarn": "^4.14",
    "node": ">=26.5.0 <27"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "patch:@ianvs/prettier-plugin-sort-imports@npm%3A4.7.1#~/.yarn/patches/@ianvs-prettier-plugin-sort-imports-npm-4.7.1-0d71bdf6a7.patch",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "ajv": "^8.20.0",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "p-retry": "^8.0.0",
    "prettier": "^3.9.4",
    "socket": "^1.1.137",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "^4.0.0",
    "yaml": "^2.9.0",
    "zx": "^8.8.5"
  },
  "resolutions": {
    "osc/serialport": "npm:empty-npm-package@1.0.0",
    "osc/ws": "^8.21.0",
    "app-builder-lib@npm:26.9.1": "patch:app-builder-lib@npm%3A26.9.1#~/.yarn/patches/app-builder-lib-npm-26.1.0-3323342f9a.patch",
    "unix-dgram": "npm:empty-npm-package@1.0.0",
    "bare-fs": "npm:empty-npm-package@1.0.0",
    "bare-path": "npm:empty-npm-package@1.0.0",
    "@types/express-serve-static-core": "^5.1.0",
    "node-gyp": "^12.3.0",
    "monaco-editor/dompurify": "npm:dompurify@^3.3.3",
    "webpack-bundle-analyzer": "^5.0.0"
  },
  "dependenciesMeta": {
    "@sentry/cli": {
      "built": true
    },
    "electron": {
      "built": true
    },
    "esbuild": {
      "built": true
    }
  }
}
