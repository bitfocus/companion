# Run companion and the webui on alternate ports, to avoid conflicts with another version
# Note: this doesnt support adjusting satellite or some other fixed ports
COMPANION_APP_PORT=8001
COMPANION_UI_PORT=5174

# Specify an alternate path to load dev modules from, instead of the module-local-dev folder inside the repository.
# COMPANION_DEV_MODULES=

# Connect the webui to an external companion instance.
# If both this and COMPANION_APP_PORT are set, this will take precedence
# UPSTREAM_URL=localhost:8000


# "Dangerous features" - these allow code to run on this computer, so are disabled by default in
# production. For convenience they default to ON in dev mode (see tools/dev.mts); set to 0 to override.
#
# Allow the internal "Run shell command" action (and any other shell command support) to run.
# COMPANION_ENABLE_SHELL_COMMAND_SUPPORT=1
# Allow loading modules otherwise held back for safety, e.g. importing custom modules from remote
# clients. Importing from this computer is always allowed regardless of this setting.
# COMPANION_ENABLE_RESTRICTED_MODULES=1
# Configure Express "trust proxy" so the real client ip is used behind a reverse proxy.
# Accepts 'loopback', or a comma/semicolon separated list of proxy addresses/subnets.
# COMPANION_TRUSTED_PROXIES=loopback
