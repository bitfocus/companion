	"tags": ["companion", "bitfocus"],
	"templating": {
		"list": [
			{
				"current": {},
				"hide": 0,
				"includeAll": false,
				"label": "Data source",
				"multi": false,
				"name": "datasource",
				"options": [],
				"query": "prometheus",
				"refresh": 1,
				"regex": "",
				"type": "datasource"
			},
			{
				"allValue": ".*",
				"current": {
					"text": "All",
					"value": "$__all"
				},
				"datasource": {
					"type": "prometheus",
					"uid": "${datasource}"
				},
				"definition": "label_values(companion_instance_info, label)",
				"hide": 0,
				"includeAll": true,
				"label": "Connection",
				"multi": true,
				"name": "connection",
				"options": [],
				"query": {
					"query": "label_values(companion_instance_info, label)",
