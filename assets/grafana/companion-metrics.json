									"mode": "fixed",
									"fixedColor": "red"
								}
							}
						]
					}
				]
			},
			"options": {
				"legend": {
					"displayMode": "list",
					"placement": "bottom"
				},
				"tooltip": {
					"mode": "multi"
				}
			},
			"targets": [
