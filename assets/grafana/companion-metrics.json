						"showPoints": "never"
					}
				},
				"overrides": [
					{
						"matcher": {
							"id": "byName",
							"options": "Limit"
						},
						"properties": [
							{
								"id": "custom.drawStyle",
								"value": "line"
							},
							{
								"id": "custom.lineStyle",
