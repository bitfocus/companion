		{
			"type": "row",
			"id": 200,
			"title": "Rendering",
			"collapsed": false,
			"gridPos": {
				"h": 1,
				"w": 24,
				"x": 0,
				"y": 9
			}
		},
		{
			"id": 20,
			"type": "timeseries",
			"title": "Native render duration (drawNative cache misses)",
			"description": "Percentiles of companion_draw_native_render_duration_seconds. Spikes here mean slow button renders.",
			"datasource": {
				"type": "prometheus",
				"uid": "${datasource}"
			},
			"gridPos": {
				"h": 8,
				"w": 12,
				"x": 0,
				"y": 10
			},
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 10,
						"showPoints": "never"
					}
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "max"]
				},
				"tooltip": {
					"mode": "multi"
				}
			},
			"targets": [
				{
					"refId": "A",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "histogram_quantile(0.50, sum(rate(companion_draw_native_render_duration_seconds_bucket[$__rate_interval])) by (le))",
					"legendFormat": "p50"
				},
				{
					"refId": "B",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "histogram_quantile(0.90, sum(rate(companion_draw_native_render_duration_seconds_bucket[$__rate_interval])) by (le))",
					"legendFormat": "p90"
				},
				{
					"refId": "C",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "histogram_quantile(0.99, sum(rate(companion_draw_native_render_duration_seconds_bucket[$__rate_interval])) by (le))",
					"legendFormat": "p99"
				},
				{
					"refId": "D",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "rate(companion_draw_native_render_duration_seconds_sum[$__rate_interval]) / clamp_min(rate(companion_draw_native_render_duration_seconds_count[$__rate_interval]), 1)",
					"legendFormat": "avg"
				}
			]
		},
		{
			"id": 21,
			"type": "timeseries",
			"title": "Draw request rate by result",
			"description": "companion_draw_requests_total (native) and companion_draw_datauri_requests_total (data-url), split by cache hit vs fresh render/encode.",
			"datasource": {
				"type": "prometheus",
				"uid": "${datasource}"
			},
			"gridPos": {
				"h": 8,
				"w": 12,
				"x": 12,
				"y": 10
			},
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"stacking": {
							"mode": "normal",
							"group": "A"
						},
						"showPoints": "never"
					}
				},
				"overrides": []
			},
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "sum"]
				},
				"tooltip": {
					"mode": "multi"
				}
			},
			"targets": [
				{
					"refId": "A",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "sum by (result) (rate(companion_draw_requests_total[$__rate_interval]))",
					"legendFormat": "native {{result}}"
				},
				{
					"refId": "B",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "sum by (result) (rate(companion_draw_datauri_requests_total[$__rate_interval]))",
					"legendFormat": "datauri {{result}}"
				}
			]
		},
		{
			"id": 22,
			"type": "gauge",
			"title": "Render cache hit ratio",
			"description": "Fraction of draw requests served from the render LRU cache.",
			"datasource": {
				"type": "prometheus",
				"uid": "${datasource}"
			},
			"gridPos": {
				"h": 7,
				"w": 6,
				"x": 0,
				"y": 18
			},
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
					"min": 0,
					"max": 1,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{
								"color": "red",
								"value": null
							},
							{
								"color": "orange",
								"value": 0.5
							},
							{
								"color": "green",
								"value": 0.8
							}
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": {
					"calcs": ["lastNotNull"]
				},
				"showThresholdLabels": false,
				"showThresholdMarkers": true
			},
			"targets": [
				{
					"refId": "A",
					"datasource": {
						"type": "prometheus",
						"uid": "${datasource}"
					},
					"expr": "sum(rate(companion_draw_requests_total{result=\"cache_hit\"}[$__rate_interval])) / clamp_min(sum(rate(companion_draw_requests_total[$__rate_interval])), 1)"
				}
			]
		},
		{
			"id": 23,
			"type": "timeseries",
