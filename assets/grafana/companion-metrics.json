			"type": "timeseries",
			"title": "ImageResults retained in memory",
			"datasource": {
				"type": "prometheus",
				"uid": "${datasource}"
			},
			"gridPos": {
				"h": 7,
				"w": 8,
				"x": 0,
				"y": 25
			},
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": {
